# hook-safety.tape — safety-guard hook blocking a dangerous command
# Record: cd claude-code-tips && vhs gifs/hook-safety.tape

Output gifs/hook-safety.gif
Set Theme "Catppuccin Mocha"
Set FontFamily "JetBrains Mono"
Set FontSize 13
Set Width 960
Set Height 350
Set Padding 20
Set TypingSpeed 30ms

Type "cat gifs/test-hook-input.json | bash hooks/safety-guard.sh"
Enter
Sleep 3s
