# mine-dryrun.tape — first-run dry-run preview
# Record: cd claude-code-tips && vhs gifs/mine-dryrun.tape

Output gifs/mine-dryrun.gif
Set Theme "Catppuccin Mocha"
Set FontFamily "JetBrains Mono"
Set FontSize 13
Set Width 960
Set Height 400
Set Padding 20
Set TypingSpeed 30ms

Type "python3 scripts/mine.py --dry-run"
Enter
Sleep 5s
