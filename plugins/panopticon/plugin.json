{
  "name": "panopticon",
  "version": "0.1.0",
  "description": "logs every single tool action to sqlite. know exactly what claude did",
  "author": {
    "name": "Ani Potts"
  },
  "license": "MIT",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/panopticon.sh"
          }
        ]
      }
    ]
  },
  "keywords": ["audit", "logging", "sqlite", "observability"]
}
