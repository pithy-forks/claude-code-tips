{
  "name": "subagent-orchestrator",
  "version": "0.1.0",
  "description": "tracks subagent lifecycle and rebalances work when teammates go idle",
  "author": {
    "name": "Ani Potts"
  },
  "license": "MIT",
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/orchestrator.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/orchestrator.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/orchestrator.sh"
          }
        ]
      }
    ]
  },
  "keywords": ["subagent", "orchestration", "scheduling", "work-stealing"]
}
