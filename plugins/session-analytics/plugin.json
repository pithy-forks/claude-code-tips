{
  "name": "session-analytics",
  "version": "0.1.0",
  "description": "tracks session patterns — duration, frequency, time-of-day, which tools you actually use",
  "author": {
    "name": "Ani Potts"
  },
  "license": "MIT",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-track.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-track.sh"
          }
        ]
      }
    ]
  },
  "keywords": ["analytics", "session", "tracking", "usage"]
}
